<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="maUI_programacao_visual.Views.Aula04.Exercicio3"
             Title="Exercicio3">
    <VerticalStackLayout Padding="30" Spacing="20">
        <Label Text="Escolha uma cor de destaque:" FontSize="18" FontAttributes="Bold" />

        <RadioButton Content="Vermelho" 
                 GroupName="cores" 
                 CheckedChanged="OnCorChanged" />

        <RadioButton Content="Azul" 
                 GroupName="cores" 
                 CheckedChanged="OnCorChanged" />

        <RadioButton Content="Verde" 
                 GroupName="cores" 
                 CheckedChanged="OnCorChanged" />

        <HorizontalStackLayout Spacing="5" Margin="0,20,0,0">
            <Label Text="Cor selecionada: " FontSize="20" />
            <Label x:Name="LabelCorStatus" 
               Text="Nenhuma" 
               FontSize="20" 
               FontAttributes="Bold" />
        </HorizontalStackLayout>
    </VerticalStackLayout>
</ContentPage>