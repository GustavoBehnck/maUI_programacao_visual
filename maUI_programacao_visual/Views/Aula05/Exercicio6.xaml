<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="maUI_programacao_visual.Views.Aula05.Exercicio6"
             Title="Exercicio6">
    <ScrollView>
        <VerticalStackLayout Padding="30" Spacing="15">
            <Label Text="Gerador de Dados Aleatórios" FontSize="22" FontAttributes="Bold" HorizontalOptions="Center" />

            <HorizontalStackLayout Spacing="10">
                <Label Text="Quantidade de números:" VerticalOptions="Center" />
                <Stepper x:Name="StepperQtde" Minimum="1" Maximum="200" Increment="5" Value="10" 
                     ValueChanged="OnStepperChanged" />
                <Label x:Name="LabelQtde" Text="10" FontAttributes="Bold" VerticalOptions="Center" />
            </HorizontalStackLayout>

            <HorizontalStackLayout Spacing="10">
                <Label Text="Valor Máximo (0 a X):" VerticalOptions="Center" />
                <Label x:Name="LabelMaximoSlider" Text="100" FontAttributes="Bold" TextColor="Green" />
            </HorizontalStackLayout>
            <Slider x:Name="SliderIntervalo" Minimum="10" Maximum="1000" Value="100" 
                ValueChanged="OnSliderChanged" />

            <Button Text="Gerar Números" Clicked="OnGerarClicked" BackgroundColor="DarkSlateBlue" TextColor="White" />

            <ProgressBar x:Name="BarraProgresso" Progress="0" ProgressColor="Orange" HeightRequest="8" />

            <Label Text="Números Gerados:" FontAttributes="Bold" />
            <Editor x:Name="EditorNumeros" IsReadOnly="True" HeightRequest="120" />

            <Border>
                <VerticalStackLayout Spacing="5">
                    <Label x:Name="LabelMedia" Text="Média: --" />
                    <Label x:Name="LabelMax" Text="Valor Máximo: --" />
                    <Label x:Name="LabelMin" Text="Valor Mínimo: --" />
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>