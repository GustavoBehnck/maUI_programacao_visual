<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="maUI_programacao_visual.Views.Aula05.Exercicio4"
             Title="Exercicio4">
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">
            <Label Text="Analisador de Texto" FontSize="22" FontAttributes="Bold" HorizontalOptions="Center" />

            <Label Text="Cole seu texto abaixo:" />
            <Editor x:Name="EditorTexto" Placeholder="Cole o texto aqui..." HeightRequest="150" />

            <HorizontalStackLayout Spacing="10">
                <Label Text="Tamanho mín. da palavra:" />
                <Label x:Name="LabelSlider" Text="1" FontAttributes="Bold" TextColor="Green" />
            </HorizontalStackLayout>
            <Slider x:Name="SliderMinimo" Minimum="1" Maximum="15" Value="1" 
                ValueChanged="OnSliderChanged" />

            <HorizontalStackLayout Spacing="10">
                <Label Text="Analisar quantas palavras?" />
                <Label x:Name="LabelStepper" Text="50" FontAttributes="Bold" TextColor="Blue" />
            </HorizontalStackLayout>
            <Stepper x:Name="StepperLimite" Minimum="1" Maximum="500" Increment="10" Value="50" 
                 ValueChanged="OnStepperChanged" />

            <ProgressBar x:Name="BarraProgresso" Progress="0" ProgressColor="Purple" />

            <Button Text="Analisar Texto" Clicked="OnAnalisarClicked" BackgroundColor="Purple" TextColor="White" />

            <Label x:Name="LabelContagem" Text="Palavras encontradas: 0" FontAttributes="Bold" />

            <Label Text="Palavras que atendem ao critério:" />
            <Editor x:Name="EditorResultado" IsReadOnly="True" HeightRequest="150"/>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>