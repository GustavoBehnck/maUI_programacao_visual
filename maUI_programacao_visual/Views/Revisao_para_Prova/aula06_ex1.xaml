<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="maUI_programacao_visual.Views.Revisao_para_Prova.aula06_ex1"
             Title="aula06_ex1">
    <VerticalStackLayout>
        <Label Text="Selecione uma Pessoa:" FontAttributes="Bold" />

        <Picker x:Name="pickerPessoas" 
            Title="Selecione alguém" 
            ItemDisplayBinding="{Binding nome}"
            SelectedIndexChanged="OnPickerSelectedIndexChanged" />

        <Frame Padding="10">
            <Label x:Name="LabelDetalhes" Text="Detalhes aparecerão aqui" />
        </Frame>

        <BoxView HeightRequest="1" Color="Gray" Margin="0,10" />

        <Label x:Name="LabelMediaAltura" Text="Média Altura: -" />
        <Label x:Name="LabelMediaIdade" Text="Média Idade: -" />
        <Label x:Name="LabelMediana" Text="Mediana (Altura): -" />
        <Label x:Name="LabelDesvioPadrao" Text="Desvio Padrão (Altura): -" />

    </VerticalStackLayout>
</ContentPage>